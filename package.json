{
  "name": "taleium",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently --names worker,vite --prefix-colors blue,green \"npm run dev:worker\" \"vite\"",
    "dev:frontend": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:worker": "wrangler dev --remote",
    "deploy": "npm run build && wrangler deploy",
    "db:migrate": "wrangler d1 execute taleium-meta --file=./migrations/001_init.sql"
  },
  "dependencies": {
    "@cloudflare/kv-asset-handler": "^0.4.2",
    "jspdf": "^4.2.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "wrangler": "^3.99.0"
  }
}
